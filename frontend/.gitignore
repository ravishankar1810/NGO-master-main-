# Add .env protection to frontend .gitignore
@"
# Node dependencies
node_modules/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store

# Environment variables (ADD THIS SECTION)
.env
.env.local
.env.*.local
.env.production
.env.development
"@ | Out-File -FilePath frontend/.gitignore -Encoding utf8

# Add the updated .gitignore
git add frontend/.gitignore