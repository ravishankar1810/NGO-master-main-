# Create root .gitignore if it doesn't exist
@"
# Environment files (BLOCK ALL .env FILES)
.env
.env.*
*.env
backend/.env
backend/.env.*
backend/server/.env
frontend/.env
frontend/.env.*

# Dependencies
node_modules/

# Build outputs
dist/
build/

# Logs
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
"@ | Out-File -FilePath .gitignore -Encoding utf8

git add .gitignore