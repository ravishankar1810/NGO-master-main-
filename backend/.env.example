MONGO_URI=mongodb+srv://your_user:your_password@cluster.mongodb.net/your_db
PORT=5000
NODE_ENV=production

# Gmail credentials for contact form emails (Nodemailer)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASS=your_gmail_app_password
ADMIN_EMAIL=your_receive_email@gmail.com

# Twilio Configuration
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXX

# Google Gemini API Key
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXX

# URLs
CLIENT_URL=https://your-frontend-app.vercel.app
SERVER_URL=https://your-backend-app.vercel.app

# JWT Secret
JWT_SECRET=your_jwt_secret_key
